{
  "name": "blog-starter",
  "version": "1.0.0",
  "packageManager": "yarn@4.3.1",
  "author": "Hamza Miloud Amar <hamzamiloudamar@gmail.com>",
  "license": "MIT",
  "repository": "git@github.com:HamzaAmar/amar-hamza.git",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "bundle-check": "ANALYZE=true yarn build",
    "start": "next start",
    "type-check:watch": "yarn type-check --watch",
    "cz": "exec < /dev/tty && git cz --hook || true",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome format --write",
    "validation": "npm-run-all format lint type-check",
    "ci": "npm run validation && npm run build",
    "clear": "concurrently \"rm -rf node_modules\" \"rm -rf .next\" \"rm -rf yarn.lock\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@biomejs/biome": "^2.3.10",
    "@marsidev/react-turnstile": "^1.4.0",
    "@next/third-parties": "^16.1.1",
    "@supabase/ssr": "0.8.0",
    "@supabase/supabase-js": "^2.89.0",
    "copy-to-clipboard": "^3.3.3",
    "date-fns": "4.1.0",
    "next": "^16.1.1",
    "next-mdx-remote": "^5.0.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.12",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "reading-time": "^1.5.0",
    "sugar-high": "^0.9.5",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.0.0",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@next/bundle-analyzer": "^16.1.1",
    "@storybook/addon-a11y": "10.2.4",
    "@storybook/addon-docs": "10.2.4",
    "@storybook/addon-onboarding": "10.2.4",
    "@storybook/addon-vitest": "10.2.4",
    "@storybook/nextjs-vite": "^10.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^22.19.3",
    "@types/nodemailer": "^6.4.21",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/rss": "0.0.32",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "axe-playwright": "^2.2.2",
    "concurrently": "^9.2.1",
    "git-cz": "^4.9.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.12.4",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.57.0",
    "rss": "^1.2.2",
    "sass": "^1.97.1",
    "schema-dts": "^1.1.5",
    "storybook": "10.2.4",
    "stylelint": "^16.26.1",
    "stylelint-color-format": "^1.1.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-order": "^7.0.0",
    "tsconfig-paths-webpack-plugin": "^3.5.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*": "yarn validation"
  }
}
